rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Lists
    match /lists/{listId} {
      // Owner can read/write/delete their own list
      allow read, write: if request.auth != null && resource.data.uid == request.auth.uid;

      // Anyone (including unauthenticated) can read a public list (share page)
      allow read: if resource.data.isPublic == true;

      // Owner can create a list
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }

    // Items
    match /items/{itemId} {
      // Owner can read/write/delete their own items (single doc + collection queries with uid filter)
      allow read, write: if request.auth != null && resource.data.uid == request.auth.uid;

      // Owner can create items
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;

      // Anyone (including unauthenticated) can read items from a public list (share page)
      allow read: if get(/databases/$(database)/documents/lists/$(resource.data.listId)).data.isPublic == true;
    }

  }
}
