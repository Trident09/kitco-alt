rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Lists
    match /lists/{listId} {
      // Owner can read/write their own list
      allow read, write: if request.auth != null && resource.data.uid == request.auth.uid;

      // Anyone authenticated can read a public list (for share page)
      allow read: if request.auth != null && resource.data.isPublic == true;

      // Allow creating a list if the uid matches the authenticated user
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }

    // Items
    match /items/{itemId} {
      // Owner can read/write their own items
      allow read, write: if request.auth != null && resource.data.uid == request.auth.uid;

      // Allow creating an item if the uid matches the authenticated user
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;

      // Allow reading items from a public list (for share page)
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/lists/$(resource.data.listId)).data.isPublic == true;
    }

  }
}
